# ============================================================
# NEXUS CYBER GATEWAY — Environment Configuration
# ============================================================
# Copy this file to ".env" and fill in your actual keys.
# NEVER commit ".env" to version control. It's in .gitignore.
# ============================================================

# ─── REFLEX LAYER (Groq API — Qwen3 32B) ───────────────────
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=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

# Groq model slug for Qwen3 32B (check Groq docs for latest slug)
GROQ_MODEL=qwen3-32b

# ─── REASONING LAYER (OpenRouter API — Qwen3 235B-A22B) ─────
# Get your key at: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=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

# OpenRouter model slug for Qwen3 235B-A22B
OPENROUTER_MODEL=qwen/qwen3-235b-a22b

# ─── BACKEND TARGET ─────────────────────────────────────────
# The internal backend that the gateway proxies traffic to.
TARGET_BACKEND=http://localhost:3000

# ─── GATEWAY SETTINGS ───────────────────────────────────────
GATEWAY_PORT=8080
HONEYPOT_PORT=9090

# ─── RATE LIMITER ───────────────────────────────────────────
# Token bucket: burst size and sustained rate (req/sec)
RATE_LIMIT_BURST=100
RATE_LIMIT_RPS=50

# ─── MTD SHUFFLE INTERVAL ───────────────────────────────────
# How often (in seconds) the backend port is rotated via CSPRNG
MTD_SHUFFLE_INTERVAL_SECS=60

# ─── DATABASE (Phase 7) ─────────────────────────────────────
POSTGRES_DSN=postgres://nexus:CHANGE_ME@localhost:5432/nexus_cyber?sslmode=require
REDIS_URL=redis://localhost:6379/0

# ─── SECURITY ───────────────────────────────────────────────
# Master secret for HMAC signing of internal tokens (min 32 chars)
NEXUS_MASTER_SECRET=CHANGE_ME_TO_A_RANDOM_32_CHAR_STRING
